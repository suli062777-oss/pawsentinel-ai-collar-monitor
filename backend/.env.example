DATABASE_URL="postgresql://pawroom:pawroom@localhost:5432/pawroom?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=4000
PAWROOM_MOCK_DATA_PATH="../data/pawroom-mock-collar-scenarios-v0.1.json"
PAWROOM_ENABLE_PRISMA_STORE=false
PAWROOM_CREATION_QUEUE=memory
# Pixel avatar generation. Keep mock for local MVP; switch to byteark after you have Volcengine/ByteDance credentials.
PAWROOM_IMAGE_PROVIDER=mock
BYTEARK_API_KEY=""
BYTEARK_IMAGE_ENDPOINT="https://ark.cn-beijing.volces.com/api/v3/images/generations"
BYTEARK_IMAGE_MODEL=""
BYTEARK_IMAGE_RESPONSE_FORMAT="b64_json"
BYTEARK_IMAGE_INPUT_MODE="base64"
BYTEARK_IMAGE_SOURCE_FIELD="image"
BYTEARK_NEGATIVE_PROMPT_FIELD="negative_prompt"
BYTEARK_IMAGE_TIMEOUT_MS=60000
